# Binaries
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go
*.out
.DS_Store
vendor/

# Node
node_modules/
package-lock.json
.pnpm-store/
# Local npm registry config (may hold a corporate/private registry URL or token) — never commit
.npmrc

# Host-staged corp CA bundle for corporate-build image support (see deploy/images/README.md) — never commit
deploy/images/corp-ca.pem

# Environment
.env
.env.local
.env.*.local

# Development
.idea/
.vscode/
*.swp
*.swo
*~
.tmp/

# Docker
docker-compose.override.yml

# compiled binaries at repo root
/wardyn
/wardynd
/wardyn-proxy
/wardyn-rec
/wardyn-runner
/wardyn-git-helper
/wardyn-tetragon-ingest

# playwright/screenshot artifacts
.playwright-mcp/
/*.png

# local, non-published scratch (configs, keys, scratch scripts)
/local/

# Generated test-report artifacts (regenerable per run). Committed durable
# files: test/reports/README.md and rollup.md. Everything else is generated.
test/reports/go/
test/reports/ui/
test/reports/e2e/
test/reports/coverage/

# Seeded e2e backend artifacts (scripts/e2e-backend.sh): built binaries, logs,
# and the wardynd recording-store scratch dir.
/.e2e-bin/
/data/
ui/test-results/
ui/playwright-report/

# Local hands-on instance artifacts (scripts/run-local.sh)
/.local-bin/

# real (non-.example) local composer configs must never be committed
/examples/composer-configs/anthropic-api.json
/examples/composer-configs/openai-api.json

# design-sync (claude.ai/design system sync) — staged scripts, build output, machine state
.ds-sync/
ds-bundle/
/.design-sync/

# Claude Code local config (contributors bring their own)
.claude/*
# Skills ship with the repo (Claude Code picks them up per-project).
!.claude/skills/

# local, non-published design & review notes (kept out of the repo)
/docs/reviews/
/docs/design/
/test/e2e/campaign/
/test/e2e/RESULTS.md

# local audit / scratch notes (never published)
/*_AUDIT.md
/.audit-*
