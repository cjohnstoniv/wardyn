*.swp
*.swo
*~
.tmp/

# Docker
docker-compose.override.yml

# compiled binaries at repo root
/wardyn
/wardynd
/wardyn-proxy
/wardyn-rec
/wardyn-runner
/wardyn-git-helper
/wardyn-tetragon-ingest

# spikes benchmark build output (regenerable: cd spikes/spire/harness && go build)
/spikes/spire/harness/spirebench

# playwright/screenshot artifacts
.playwright-mcp/
/*.png

# maintainer's local, non-OSS scratch (personal WSL-migration config, keys, scripts)
/local/

# Generated test-report artifacts (regenerable per run). Committed durable files:
# test/reports/README.md, rollup.md, coverage-dashboard.md, and the per-component
# review ledgers under test/reports/components/. Everything else is generated.
test/reports/go/
test/reports/ui/
test/reports/e2e/
test/reports/coverage/

# Seeded e2e backend artifacts (scripts/e2e-backend.sh): built binaries, logs,
# and the wardynd recording-store scratch dir.
/.e2e-bin/
/data/
ui/test-results/
ui/playwright-report/

# Local hands-on instance artifacts (scripts/run-local.sh)
/.local-bin/

# real (non-.example) local composer configs must never be committed
/examples/composer-configs/anthropic-api.json
/examples/composer-configs/openai-api.json

# design-sync (claude.ai/design system sync) — staged scripts, build output, machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
