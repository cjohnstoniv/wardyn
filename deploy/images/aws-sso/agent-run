#!/usr/bin/env bash
# /usr/local/bin/agent-run — Wardyn agent launcher for the aws-sso login image.
#
# CONTRACT (all agent images must implement this interface):
#   Usage: agent-run "<task text>"
#   Usage: agent-run --idle
#   Usage: agent-run --selftest
#
# This image has no LLM harness — its only job is to host an interactive
# `aws sso login --no-browser --use-device-code` session. Both normal task
# mode and idle mode converge on that same command; there is no "task" for an
# aws-sso run to interpret, so the task text (if any) is logged, not consumed.
# The intended usage is `wardyn attach` into an idle run and typing the login
# command by hand (the device-code flow prints a URL + code for the operator
# to open elsewhere), but `agent-run "<anything>"` also runs it directly for a
# non-interactive/scripted launch — the driver's session recorder captures
# the printed URL/code either way.
#
# --selftest mode (no AWS credentials needed):
#   Verifies required binaries and prints env wiring. Side-effect-free: never
#   calls `aws`. Used by e2e validation without a live login.
set -euo pipefail

# Shared functions (install_mitm_ca, install_artifact_config,
# provision_git_helper_secret, clone_one, dispatch_repo_clones,
# resolve_workdir) — identical across every agent image's agent-run.
source /usr/local/bin/agent-run-lib.sh

# selftest_report_shared prints the TLS-MITM CA, repo-wiring, and git-helper
# selftest reports. Byte-identical to claude-code's/codex-cli's block; kept in
# a function so the images share one wording. Report-only: it echoes/inspects,
# never mutates $ok or exits — the PASS/FAIL decision stays with the caller.
selftest_report_shared() {
    echo "--- TLS-MITM CA trust (selftest: report only) ---"
    if [[ -n "${WARDYN_MITM_CA_PEM:-}" ]]; then
        [[ -f /tmp/wardyn/mitm-ca.pem ]] \
            && echo "  proxy CA: INSTALLED (/tmp/wardyn/mitm-ca.pem)" \
            || echo "  proxy CA: DELIVERED but not yet installed (installed at idle/task start)"
        if [[ -f /tmp/wardyn/ca-bundle.pem ]]; then
            sys_found=0
            for c in /etc/ssl/certs/ca-certificates.crt /etc/ssl/cert.pem /etc/pki/tls/certs/ca-bundle.crt; do
                [[ -f "$c" ]] && sys_found=1 && break
            done
            if [[ $sys_found -eq 1 ]]; then
                echo "  combined bundle: PRESENT (/tmp/wardyn/ca-bundle.pem = system roots + proxy CA)"
            else
                echo "  combined bundle: PROXY-CA-ONLY (no system CA bundle in image; non-MITM TLS hosts will not verify)"
            fi
        else
            echo "  combined bundle: not yet assembled"
        fi
    else
        echo "  proxy CA: not delivered (run did not opt into TLS-MITM)"
    fi
    echo "--- repo wiring (selftest never clones) ---"
    echo "  WARDYN_REPO_URL=${WARDYN_REPO_URL:-<unset (no repo to clone)>}"
    echo "  WARDYN_REPO_SLUG=${WARDYN_REPO_SLUG:-<unset>}"
    if [ -n "$(find "${HOME}/work" -maxdepth 2 -mindepth 1 -type d -name ".git" 2>/dev/null | head -1)" ]; then
        echo "  workspace repo: PRESENT (a .git exists under ~/work)"
    else
        echo "  workspace repo: ABSENT (would clone WARDYN_REPO_URL if set)"
    fi
    echo "--- git credential helper ---"
    echo "  WARDYN_GIT_PAT_GRANTS=${WARDYN_GIT_PAT_GRANTS:-<unset (no git_pat grants)>}"
    git config --system --get credential.helper 2>/dev/null \
        && echo "  OK (system config, global)" || echo "  MISSING (system gitconfig not wired)"
    if [[ -n "${WARDYN_GITHUB_GRANT_ID:-}" || -n "${WARDYN_GIT_PAT_GRANTS:-}" ]]; then
        echo "  caller-auth gate: ACTIVE at task time (a git grant is present; agent-run will provision WARDYN_GIT_HELPER_SECRET + a 0400 secret file)"
    else
        echo "  caller-auth gate: not provisioned (no git grant; helper fails open so unmatched-host git is unaffected)"
    fi
}

# ── selftest ─────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--selftest" ]]; then
    echo "=== wardyn agent-run selftest (aws-sso) ==="
    ok=1
    for bin in wardyn-rec wardyn-git-helper git aws; do
        if command -v "$bin" >/dev/null 2>&1; then
            echo "  FOUND   $bin ($(command -v "$bin"))"
        else
            echo "  MISSING $bin"
            ok=0
        fi
    done
    echo "--- env wiring ---"
    echo "  HTTP_PROXY=${HTTP_PROXY:-<unset>}"
    echo "  HTTPS_PROXY=${HTTPS_PROXY:-<unset>}"
    echo "  NO_PROXY=${NO_PROXY:-<unset>}"
    echo "  WARDYN_PROXY_URL=${WARDYN_PROXY_URL:-<unset>}"
    echo "  AWS_PAGER=${AWS_PAGER-<unset>}"
    selftest_report_shared
    if [[ $ok -eq 1 ]]; then
        echo "=== selftest PASS ==="
        exit 0
    else
        echo "=== selftest FAIL ==="
        exit 1
    fi
fi

# ── shared prep (both idle and normal task mode) ─────────────────────────────
: "${HOME:=/home/agent}"; export HOME
install_mitm_ca
install_artifact_config
materialize_aws_sso_config
provision_git_helper_secret
workdir="${HOME}/work"
mkdir -p "$workdir"
configure_git_broker_insteadof
dispatch_repo_clones
resolve_workdir

# ── idle mode (INTERACTIVE runs) ──────────────────────────────────────────────
# Prepare the workspace then hold open for `wardyn attach`, where the operator
# runs `aws sso login --no-browser --use-device-code` by hand and follows the
# printed URL/code.
if [[ "${1:-}" == "--idle" ]]; then
    mkdir -p "$HOME/.wardyn"
    printf '%s\n' "$workdir" > "$HOME/.wardyn/workdir"
    : > "$HOME/.wardyn/prep-done"
    echo "agent-run: idle mode — workspace prepared ($workdir), holding open for attach" >&2
    echo "agent-run: run 'aws sso login --no-browser --use-device-code' in the attached shell" >&2
    exec sleep infinity
fi

# ── normal task mode ─────────────────────────────────────────────────────────
cd "$workdir"

# Exec task mode (BYOA/CI lane): run the task as a plain shell command instead
# of the login flow. Never returns when WARDYN_TASK_MODE=exec.
maybe_exec_task_mode "${1:-}"

# There is no LLM/task to interpret here — this image's only job is the SSO
# device-code login. The task argument (if any) is informational only.
if [[ -n "${1:-}" ]]; then
    echo "agent-run: task text ignored ('${1}') — aws-sso always runs the SSO login flow" >&2
fi
echo "agent-run: launching 'aws sso login --no-browser --use-device-code'" >&2
exec aws sso login --no-browser --use-device-code
