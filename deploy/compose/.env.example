# Copy this to `.env` (gitignored) to customize the compose demo — docker compose
# auto-loads `.env` from this directory. This example enables the AI Run Composer with
# the no-API-key "fake" backend so the New Run wizard's "Describe your task" flow works
# out of the box. Swap in a real backend from ../../examples/composer-configs/.
#
# `make setup` (scripts/up.sh up) auto-writes/updates this file for you on every
# run: WARDYN_AGE_KEY (minted once, persisted), WARDYN_LOCAL_MODE=true,
# WARDYN_DEFAULT_POLICY (auto-picked: composer-dev.json if a real model path is
# configured — a non-fake WARDYN_COMPOSER_CONFIG or an exported ANTHROPIC_API_KEY/
# OPENAI_API_KEY — since only that ceiling admits the api_key grant + LLM egress a
# composed run needs; otherwise default.json if gVisor/runsc is available, else
# demo.json — an existing value here is honored), and WARDYN_COMPOSER_CONFIG (only
# if unset). You normally don't need to hand-edit this file at all — it's here for
# manual `docker compose up` use and for overriding `make setup`'s picks.
#
# SSO (Dex) is opt-in and OFF by default: `make setup` never starts it. Bring it
# up yourself with `docker compose --profile sso up` and set WARDYN_OIDC_ISSUER
# (see deploy/compose/README.md).

# --- AI Run Composer (OFF by default; empty disables it) ---
# Fake = deterministic demo proposals, no API key. For real prompt-driven suggestions
# use examples/composer-configs/{anthropic-api,openai-api}.json.example (needs a key) or
# claude-cli-opus.json (host-mode + your Claude subscription).
WARDYN_COMPOSER_CONFIG={"default":"dev","backends":[{"name":"dev","wire":"fake","model":"demo"}]}

# --- Optional: local no-auth mode (single developer machine) ---
# Open http://localhost:8080 with no SSO/token. Leave unset to keep the token/Dex demo.
# WARDYN_LOCAL_MODE=true

# --- Optional: pin an age key so secrets survive restarts ---
# Without this, wardynd generates a NEW ephemeral key each boot and cannot decrypt
# secrets persisted under the previous key after a container recreate (it fails closed
# with "no identity matched any of the recipients"). On first boot wardynd logs a
# freshly generated AGE-SECRET-KEY-... — copy it here to make restarts durable.
# WARDYN_AGE_KEY=AGE-SECRET-KEY-...
