{
  "allowed_domains": [
    "api.anthropic.com",
    "github.com",
    "*.githubusercontent.com",
    "proxy.golang.org",
    "registry.npmjs.org"
  ],
  "denied_domains": [],
  "first_use_approval": "deny_with_review",
  "allowed_methods": [],
  "min_confinement_class": "CC1",
  "eligible_grants": [
    {
      "kind": "api_key",
      "scope": {
        "host": "api.anthropic.com",
        "header": "x-api-key",
        "format": "%s",
        "secret_name": "anthropic-api-key"
      },
      "ttl_seconds": 3600,
      "requires_approval": false
    },
    {
      "kind": "github_token",
      "scope": {
        "repos": [],
        "permissions": {
          "contents": "read"
        }
      },
      "ttl_seconds": 3600,
      "requires_approval": true
    }
  ],
  "auto_stop_after_sec": 0
}
